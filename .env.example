# Server-side only (Netlify environment variables — never commit real values)

# bcrypt hash of the family viewing password
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10));"
VIEW_PASSWORD_HASH=

# bcrypt hash of the editing password
EDIT_PASSWORD_HASH=

# Random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=

# Fine-grained GitHub PAT with contents read+write on family_tree_data repo only
GITHUB_TOKEN=

# Your GitHub username
DATA_REPO_OWNER=

# Your private data repository name
DATA_REPO_NAME=family_tree_data
